<!--
  Lab ESL listener. Default password ClueCon is for local lab ONLY.
  Override at runtime via FreeSWITCH env / secrets in non-lab deploys.
  Edge connects with FREESWITCH_ESL_PASSWORD (compose default: ClueCon).
-->
<configuration name="event_socket.conf" description="Socket Client">
  <settings>
    <param name="nat-map" value="false"/>
    <param name="listen-ip" value="0.0.0.0"/>
    <param name="listen-port" value="8021"/>
    <param name="password" value="ClueCon"/>
  </settings>
</configuration>
